# MeetAssistant — environment configuration
# Copy this file to `.env` and fill in your real values.

# ===== Security =====
SECRET_KEY=change-me-to-a-random-string
ADMIN_TOKEN=change-me-to-a-secure-admin-token

# ===== Speech-to-text (SiliconFlow) =====
ASR_API_KEY=your-siliconflow-api-key
ASR_API_URL=https://api.siliconflow.cn/v1/audio/transcriptions
ASR_MODEL=FunAudioLLM/SenseVoiceSmall

# ===== Meeting summary (LLM) =====
LLM_API_KEY=your-llm-api-key
LLM_API_URL=https://api.linkapi.org/v1/chat/completions
LLM_MODEL=gemini-2.5-flash-preview-05-20
LLM_TEMPERATURE=0.2

# ===== Server =====
PORT=5000
FLASK_ENV=production
HOST=0.0.0.0

# ===== Gunicorn (Production) =====
USE_GUNICORN=true
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

# ===== Limits =====
MAX_UPLOAD_MB=100
API_TIMEOUT_SEC=300